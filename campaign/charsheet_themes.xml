<root>
  <windowclass name="charsheet_themes">
    <script>
      local function getIdentityLabelForFamily(sFamily)
        if sFamily == "Self" then
          return "Identity";
        elseif sFamily == "Noise" then
          return "Itch";
        elseif sFamily == "Mythos" then
          return "Ritual";
        end
        return "NA";
      end

      function updateTheme1IdentityLabel()
        theme1_identity_label.setValue(getIdentityLabelForFamily(theme1_family.getValue()));
      end

      function updateTheme2IdentityLabel()
        theme2_identity_label.setValue(getIdentityLabelForFamily(theme2_family.getValue()));
      end

      function updateTheme3IdentityLabel()
        theme3_identity_label.setValue(getIdentityLabelForFamily(theme3_family.getValue()));
      end

      function updateTheme4IdentityLabel()
        theme4_identity_label.setValue(getIdentityLabelForFamily(theme4_family.getValue()));
      end

      function onInit()
        updateTheme1IdentityLabel();
        updateTheme2IdentityLabel();
        updateTheme3IdentityLabel();
        updateTheme4IdentityLabel();
      end
    </script>
