<?xml version="1.0" encoding="utf-8"?>
<root>
  <windowclass name="charsheet_themes">
    <script>
      local _aThemeControlSuffixes = {
        "frame",
        "name_frame",
        "name",
        "family_label",
        "family_frame",
        "family",
        "powertags_label",
        "tag1_frame",
        "tag1_checked",
        "tag1_name",
        "tag2_frame",
        "tag2_checked",
        "tag2_name",
        "tag3_frame",
        "tag3_checked",
        "tag3_name",
        "tag4_frame",
        "tag4_checked",
        "tag4_name",
        "tag5_frame",
        "tag5_checked",
        "tag5_name",
        "tag6_frame",
        "tag6_checked",
        "tag6_name",
        "weaknesstags_label",
        "tag7_frame",
        "tag7_checked",
        "tag7_name",
        "tag8_frame",
        "tag8_checked",
        "tag8_name",
        "identity_label",
        "identity_frame",
        "identity",
        "specialname_label",
        "specialname_frame",
        "specialname",
        "upgrades_label",
        "upgrade1",
        "upgrade2",
        "upgrade3",
        "specialtext"
      };

      local function getIdentityLabelForFamily(sFamily)
        if sFamily == "Self" then
          return "Identity";
        elseif sFamily == "Noise" then
          return "Itch";
        elseif sFamily == "Mythos" then
          return "Ritual";
        end
        return "NA";
      end

      local function setThemeControlsVisible(nTheme, bVisible)
        local sPrefix = string.format("theme%d_", nTheme);
        for _, sSuffix in ipairs(_aThemeControlSuffixes) do
          local c = self[sPrefix .. sSuffix];
          if c then
            c.setVisible(bVisible);
          end
        end
      end

      local function bringThemeControlsToFront(nTheme)
        local sPrefix = string.format("theme%d_", nTheme);
        for _, sSuffix in ipairs(_aThemeControlSuffixes) do
          local c = self[sPrefix .. sSuffix];
          if c then
            if c.bringToFront then
              c.bringToFront();
            end
          end
        end
      end

      local function updateThemeFrameStyles(nTheme)
        for i = 1, 4 do
          local cFrame = self[string.format("theme%d_frame", i)];
          if cFrame then
            if i == nTheme then
              cFrame.setFrame("metalplate");
            else
              cFrame.setFrame("groupbox");
            end
          end
        end
      end

      local function updateThemeTabButtons(nTheme)
        if theme_tab1 then
          theme_tab1.setValue((nTheme == 1) and 1 or 0);
        end
        if theme_tab2 then
          theme_tab2.setValue((nTheme == 2) and 1 or 0);
        end
        if theme_tab3 then
          theme_tab3.setValue((nTheme == 3) and 1 or 0);
        end
        if theme_tab4 then
          theme_tab4.setValue((nTheme == 4) and 1 or 0);
        end
      end

      function selectThemeTab(nTheme)
        local n = tonumber(nTheme) or 1;
        n = math.max(1, math.min(4, n));

        updateThemeFrameStyles(n);
        for i = 1, 4 do
          if i ~= n then
            bringThemeControlsToFront(i);
          end
        end
        bringThemeControlsToFront(n);
        updateThemeTabButtons(n);
      end

      function updateTheme1IdentityLabel()
        theme1_identity_label.setValue(getIdentityLabelForFamily(theme1_family.getValue()));
      end

      function updateTheme2IdentityLabel()
        theme2_identity_label.setValue(getIdentityLabelForFamily(theme2_family.getValue()));
      end

      function updateTheme3IdentityLabel()
        theme3_identity_label.setValue(getIdentityLabelForFamily(theme3_family.getValue()));
      end

      function updateTheme4IdentityLabel()
        theme4_identity_label.setValue(getIdentityLabelForFamily(theme4_family.getValue()));
      end

      function onInit()
        updateTheme1IdentityLabel();
        updateTheme2IdentityLabel();
        updateTheme3IdentityLabel();
        updateTheme4IdentityLabel();
        selectThemeTab(1);
      end
    </script>
