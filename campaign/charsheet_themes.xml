<?xml version="1.0" encoding="utf-8"?>
<root>
  <windowclass name="charsheet_themes">
    <script>
      local _nSelectedTheme = nil;
      local _aThemeControlSuffixes = {
        "frame",
        "name_frame",
        "name",
        "family_label",
        "family_frame",
        "family",
        "powertags_label",
        "tag1_frame",
        "tag1_checked",
        "tag1_name",
        "tag1_checked_after",
        "tag2_frame",
        "tag2_checked",
        "tag2_name",
        "tag2_checked_after",
        "tag3_frame",
        "tag3_checked",
        "tag3_name",
        "tag3_checked_after",
        "tag4_frame",
        "tag4_checked",
        "tag4_name",
        "tag4_checked_after",
        "tag5_frame",
        "tag5_checked",
        "tag5_name",
        "tag5_checked_after",
        "tag6_frame",
        "tag6_checked",
        "tag6_name",
        "tag6_checked_after",
        "weaknesstags_label",
        "tag7_frame",
        "tag7_checked",
        "tag7_name",
        "tag8_frame",
        "tag8_checked",
        "tag8_name",
        "identity_label",
        "identity_frame",
        "identity",
        "specialname_label",
        "special_checked",
        "specialname_frame",
        "specialname",
        "upgrades_label",
        "upgrade1",
        "upgrade2",
        "upgrade3",
        "specialtext"
      };

      local function getIdentityLabelForFamily(sFamily)
        if sFamily == "Self" then
          return "Identity";
        elseif sFamily == "Noise" then
          return "Itch";
        elseif sFamily == "Mythos" then
          return "Ritual";
        end
        return "NA";
      end

      local function setThemeControlsVisible(nTheme, bVisible)
        local sPrefix = string.format("theme%d_", nTheme);
        for _, sSuffix in ipairs(_aThemeControlSuffixes) do
          local c = self[sPrefix .. sSuffix];
          if c then
            c.setVisible(bVisible);
          end
        end
      end

      local function bringThemeControlsToFront(nTheme)
        local sPrefix = string.format("theme%d_", nTheme);
        for _, sSuffix in ipairs(_aThemeControlSuffixes) do
          local c = self[sPrefix .. sSuffix];
          if c then
            if c.bringToFront then
              c.bringToFront();
            end
          end
        end
      end

      local function shiftThemeControlsY(nTheme, nDelta)
        local sPrefix = string.format("theme%d_", nTheme);
        for _, sSuffix in ipairs(_aThemeControlSuffixes) do
          local c = self[sPrefix .. sSuffix];
          if c and c.getStaticBounds and c.setStaticBounds then
            local x, y, w, h = c.getStaticBounds();
            if x and y and w and h then
              c.setStaticBounds(x, y + nDelta, w, h);
            end
          end
        end
      end

      local function updateThemeFrameStyles(nTheme)
        local function getThemeFrameName(nFrameTheme)
          local cFamily = self[string.format("theme%d_family", nFrameTheme)];
          local sFamily = "";
          if cFamily and cFamily.getValue then
            sFamily = cFamily.getValue() or "";
          end

          if sFamily == "Self" then
            return "groupboxred";
          elseif sFamily == "Noise" then
            return "groupboxtq";
          elseif sFamily == "Mythos" then
            return "groupboxpurp";
          end
          return "groupbox";
        end

        for i = 1, 4 do
          local cFrame = self[string.format("theme%d_frame", i)];
          if cFrame then
            cFrame.setFrame(getThemeFrameName(i));
          end
        end
      end

      local function updateThemeTabButtons(nTheme)
        if theme_tab1 then
          theme_tab1.setValue((nTheme == 1) and 1 or 0);
        end
        if theme_tab2 then
          theme_tab2.setValue((nTheme == 2) and 1 or 0);
        end
        if theme_tab3 then
          theme_tab3.setValue((nTheme == 3) and 1 or 0);
        end
        if theme_tab4 then
          theme_tab4.setValue((nTheme == 4) and 1 or 0);
        end
      end

      local function getTagRollOutcome(nTotal)
        if nTotal > 9 then
          return "STRONG HIT";
        elseif nTotal > 6 then
          return "MIXED HIT";
        end
        return "MISS";
      end

      local function onTagRollResult(rSource, _, rRoll)
        local nTotal = ActionsManager.total(rRoll);
        local sOutcome = getTagRollOutcome(nTotal);

        local rMessage = ActionsManager.createActionMessage(rSource, rRoll);
        local sBaseText = rMessage.text or "[TAG ROLL]";
        rMessage.text = string.format("%s [%s]", sBaseText, sOutcome);
        Comm.deliverChatMessage(rMessage);

        if theme_roll_tagnumber then
          theme_roll_tagnumber.setValue(0);
        end
      end

      function selectThemeTab(nTheme)
        local n = tonumber(nTheme) or 1;
        n = math.max(1, math.min(4, n));

        if _nSelectedTheme and _nSelectedTheme ~= n then
          shiftThemeControlsY(_nSelectedTheme, -20);
        end
        if _nSelectedTheme ~= n then
          shiftThemeControlsY(n, 20);
          _nSelectedTheme = n;
        end

        updateThemeFrameStyles(n);
        for i = 1, 4 do
          if i ~= n then
            bringThemeControlsToFront(i);
          end
        end
        bringThemeControlsToFront(n);
        updateThemeTabButtons(n);
      end

      function performTagRoll(draginfo)
        local nTag = 0;
        if theme_roll_tagnumber then
          nTag = tonumber(theme_roll_tagnumber.getValue()) or 0;
        end

        local rActor = nil;
        local nodeChar = getDatabaseNode();
        if nodeChar then
          rActor = ActorManager.resolveActor(nodeChar);
        end

        local rRoll = {
          sType = "tagroll",
          sDesc = string.format("[TAG ROLL] 2d6 + %d", nTag),
          aDice = { "d6", "d6" },
          nMod = nTag
        };
        ActionsManager.performAction(draginfo, rActor, rRoll);
      end

      function updateTheme1IdentityLabel()
        theme1_identity_label.setValue(getIdentityLabelForFamily(theme1_family.getValue()));
        updateThemeFrameStyles(_nSelectedTheme or 1);
      end

      function updateTheme2IdentityLabel()
        theme2_identity_label.setValue(getIdentityLabelForFamily(theme2_family.getValue()));
        updateThemeFrameStyles(_nSelectedTheme or 1);
      end

      function updateTheme3IdentityLabel()
        theme3_identity_label.setValue(getIdentityLabelForFamily(theme3_family.getValue()));
        updateThemeFrameStyles(_nSelectedTheme or 1);
      end

      function updateTheme4IdentityLabel()
        theme4_identity_label.setValue(getIdentityLabelForFamily(theme4_family.getValue()));
        updateThemeFrameStyles(_nSelectedTheme or 1);
      end

      function onInit()
        ActionsManager.initAction("tagroll");
        if GameSystem and GameSystem.actions and GameSystem.actions.tagroll then
          GameSystem.actions.tagroll.bUseModStack = "false";
        end
        if not ActionsManager.getResultHandler("tagroll") then
          ActionsManager.registerResultHandler("tagroll", onTagRollResult);
        end

        updateTheme1IdentityLabel();
        updateTheme2IdentityLabel();
        updateTheme3IdentityLabel();
        updateTheme4IdentityLabel();
        selectThemeTab(1);
      end
